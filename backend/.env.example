# BitGarden backend — environment variable template
# Copy this file to .env and fill in the values for your environment.

NODE_ENV=production
PORT=3001

# Restrict CORS to your deployed frontend origin.
# Required in production — leave blank only for local dev (allows all origins).
CORS_ORIGIN=https://bitgarden.yourdomain.com

# Optional: path to the SQLite database file.
# Defaults to backend/bitgarden.db if not set.
# DB_PATH=/data/bitgarden.db
